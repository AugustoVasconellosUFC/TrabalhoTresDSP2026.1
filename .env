# Configurações do MongoDB (Docker)
MONGO_USER=admin
MONGO_PASSWORD=senha_segura
MONGO_PORT=27017
# Use a linha abaixo para conexão com o banco local via Docker:
MONGO_URL=mongodb://admin:senha_segura@mongo:27017/trabalhotres?authSource=admin

# Configurações do MongoDB (Atlas / Nuvem)
# Para alternar para a nuvem, basta descomentar a linha abaixo e comentar a MONGO_URL acima:
# MONGO_URL=mongodb+srv://<usuario>:<senha>@cluster0.xxxxxx.mongodb.net/trabalhotres?retryWrites=true&w=majority

# Configurações do MinIO (Docker)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_senha_segura
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=produtos-bucket